# AI Sorting Feature Configuration
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored by default (*.local in .gitignore).
# NEVER prefix AI_API_KEY with VITE_ — it must stay server-side only.

# Provider: anthropic | openai | mistral
AI_PROVIDER=anthropic

# Your secret API key for the chosen provider
AI_API_KEY=your-api-key-here

# Model to use. Defaults per provider if omitted:
#   anthropic → claude-haiku-4-5-20251001
#   openai    → gpt-4o-mini
#   mistral   → mistral-small-latest
AI_MODEL=claude-haiku-4-5-20251001
